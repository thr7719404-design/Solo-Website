# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/solo_ecommerce?schema=public"

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_ACCESS_SECRET="your-super-secret-access-token-key-change-this-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-this-in-production-min-32-chars"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=3000
NODE_ENV="development"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5000"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_STRICT_TTL=900
THROTTLE_STRICT_LIMIT=5

# Payment (Stripe)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Email (SMTP)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_SECURE="false"
EMAIL_FROM="noreply@solo-ecommerce.com"

# File Upload & Storage
MAX_FILE_SIZE=5242880
UPLOAD_PATH="./uploads"
STORAGE_TYPE="local"  # "local" or "s3"

# AWS S3 (only needed when STORAGE_TYPE=s3)
AWS_REGION="me-south-1"
AWS_S3_BUCKET="solo-ecommerce-media"
AWS_S3_ENDPOINT=""         # Optional: for MinIO/DO Spaces
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_CDN_URL=""          # Optional: CDN URL prefix

# Redis (for rate limiting & caching)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_THROTTLE_DB=1

# Admin Default Credentials (for seeding)
ADMIN_EMAIL="admin@solo-ecommerce.com"
ADMIN_PASSWORD="ChangeThisPassword123!"

# Application
APP_NAME="Solo Ecommerce"
APP_URL="https://solo-ecommerce.com"
