# Media Upload Configuration
# Add these to your .env file

# Storage Configuration
STORAGE_TYPE=local  # Options: local, s3, gcs
UPLOAD_DIR=./uploads  # Local storage directory
UPLOAD_BASE_URL=http://localhost:3000/uploads  # Public URL for uploaded files
APP_URL=http://localhost:3000  # Application URL

# File Upload Limits
MAX_FILE_SIZE=5242880  # 5MB in bytes (5 * 1024 * 1024)

# AWS S3 Configuration (if using S3)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_CDN_URL=https://cdn.yourdomain.com  # Optional CloudFront URL

# Google Cloud Storage Configuration (if using GCS)
# GCS_BUCKET=your-bucket-name
# GCS_PROJECT_ID=your-project-id
# GCS_KEY_FILE=./path-to-service-account-key.json
