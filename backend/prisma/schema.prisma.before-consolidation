generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["inventory", "public"]
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  firstName               String?
  lastName                String?
  phone                   String?
  role                    UserRole                 @default(CUSTOMER)
  isActive                Boolean                  @default(true)
  emailVerified           Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  lastLoginAt             DateTime?
  addresses               Address[]
  analyticsEvents         AnalyticsEvent[]
  cart                    Cart[]
  emailVerificationTokens EmailVerificationToken[]
  favorites               Favorite[]
  loyaltyWallet           LoyaltyWallet?
  orders                  Order[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  savedPaymentMethods     SavedPaymentMethod[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
  @@schema("public")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
  @@schema("public")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
  @@schema("public")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verification_tokens")
  @@schema("public")
}

model LoyaltyWallet {
  id               String               @id @default(uuid())
  userId           String               @unique
  balanceAed       Decimal              @default(0) @db.Decimal(10, 2)
  totalEarnedAed   Decimal              @default(0) @db.Decimal(10, 2)
  totalRedeemedAed Decimal              @default(0) @db.Decimal(10, 2)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  transactions     LoyaltyTransaction[]
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loyalty_wallets")
  @@schema("public")
}

model LoyaltyTransaction {
  id          String                 @id @default(uuid())
  walletId    String
  type        LoyaltyTransactionType
  amountAed   Decimal                @db.Decimal(10, 2)
  description String?
  orderId     String?
  createdAt   DateTime               @default(now())
  wallet      LoyaltyWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([orderId])
  @@index([createdAt])
  @@map("loyalty_transactions")
  @@schema("public")
}

model SavedPaymentMethod {
  id                      String   @id @default(uuid())
  userId                  String
  provider                String   @default("stripe")
  providerPaymentMethodId String
  brand                   String
  last4                   String   @db.VarChar(4)
  expMonth                Int
  expYear                 Int
  isDefault               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isDefault])
  @@map("saved_payment_methods")
  @@schema("public")
}

model Address {
  id             String   @id @default(uuid())
  userId         String
  firstName      String
  lastName       String
  addressLine1   String
  addressLine2   String?
  city           String
  postalCode     String?
  phone          String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  label          String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ordersBilling  Order[]  @relation("BillingAddress")
  ordersShipping Order[]  @relation("ShippingAddress")

  @@index([userId])
  @@map("addresses")
  @@schema("public")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("favorites")
  @@schema("public")
}

model ProductOverride {
  id                      String     @id(map: "v2_product_overrides_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id              Int        @unique(map: "v2_product_overrides_product_id_key")
  is_featured_override    Boolean?
  is_new_override         Boolean?
  is_best_seller_override Boolean?
  homepage_rank           Int?
  custom_price_aed        Decimal?   @db.Decimal(10, 2)
  custom_sale_price_aed   Decimal?   @db.Decimal(10, 2)
  is_on_sale              Boolean    @default(false)
  product_sale_percent    Decimal?   @db.Decimal(5, 2)
  product_sale_name       String?    @db.VarChar(50)
  product_sale_starts_at  DateTime?  @db.Timestamp(6)
  product_sale_ends_at    DateTime?  @db.Timestamp(6)
  custom_description      String?
  custom_long_description String?
  meta_title              String?    @db.VarChar(200)
  meta_description        String?    @db.VarChar(500)
  meta_keywords           String?    @db.VarChar(500)
  notes                   String?
  created_at              DateTime   @default(now()) @db.Timestamp(6)
  updated_at              DateTime   @default(now()) @db.Timestamp(6)
  created_by              String?    @db.Uuid
  updated_by              String?    @db.Uuid
  products                InvProduct @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "v2_product_overrides_product_id_fkey")

  @@index([product_id], map: "idx_product_overrides_product_id")
  @@map("product_overrides")
  @@schema("public")
}

model Package {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  description     String?
  longDescription String?
  image           String?
  price           Decimal       @db.Decimal(10, 2)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cartItems       CartItem[]
  orderItems      OrderItem[]
  items           PackageItem[]

  @@index([slug])
  @@index([isFeatured])
  @@index([isActive])
  @@map("packages")
  @@schema("public")
}

model PackageItem {
  id        String  @id @default(uuid())
  packageId String
  quantity  Int     @default(1)
  productId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, productId])
  @@index([packageId])
  @@index([productId])
  @@map("package_items")
  @@schema("public")
}

model Cart {
  id            String     @id @default(uuid())
  userId        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  promoCode     String?    @db.VarChar(50)
  promoCodeId   String?
  promoDiscount Decimal?   @db.Decimal(10, 2)
  guestKey      String?    @db.Uuid
  createdFrom   String?    @db.VarChar(30)
  items         CartItem[]
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
  @@schema("public")
}

model CartItem {
  id        String       @id @default(uuid())
  cartId    String
  type      CartItemType
  packageId String?
  quantity  Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  productId Int?
  cart      Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  package   Package?     @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productId])
  @@index([packageId])
  @@map("cart_items")
  @@schema("public")
}

model Order {
  id                      String               @id @default(uuid())
  orderNumber             String               @unique
  userId                  String
  status                  OrderStatus          @default(PENDING)
  paymentStatus           PaymentStatus        @default(PENDING)
  shippingAddressId       String
  billingAddressId        String
  shippingMethod          ShippingMethod
  shippingCost            Decimal              @db.Decimal(10, 2)
  trackingNumber          String?
  subtotal                Decimal              @db.Decimal(10, 2)
  discount                Decimal              @default(0) @db.Decimal(10, 2)
  tax                     Decimal              @db.Decimal(10, 2)
  total                   Decimal              @db.Decimal(10, 2)
  promoCode               String?
  paymentIntentId         String?
  notes                   String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  paidAt                  DateTime?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  paymentMethod           PaymentMethod        @default(CREDIT_CARD)
  billingInvoiceCompany   String?              @db.VarChar(60)
  billingInvoiceVatNumber String?              @db.VarChar(60)
  loyaltyRedeemAed        Decimal?             @db.Decimal(10, 2)
  loyaltyEarnAed          Decimal?             @default(0) @db.Decimal(10, 2)
  statusMasterId          String?
  shippingCompany         String?
  trackingUrl             String?
  currencyCode            String               @default("AED") @db.VarChar(3)
  discountExclVat         Decimal?             @default(0) @db.Decimal(12, 2)
  globalSaleId            String?
  globalSaleName          String?              @db.VarChar(100)
  globalSalePercent       Decimal?             @db.Decimal(5, 4)
  promoDiscountType       String?              @db.VarChar(20)
  promoDiscountValue      Decimal?             @db.Decimal(10, 2)
  shippingExclVat         Decimal?             @db.Decimal(12, 2)
  shippingVatAmount       Decimal?             @db.Decimal(12, 2)
  subtotalExclVat         Decimal?             @db.Decimal(12, 2)
  totalInclVat            Decimal?             @db.Decimal(12, 2)
  vatAmount               Decimal?             @db.Decimal(12, 2)
  vatRateSnapshot         Decimal?             @db.Decimal(5, 4)
  invoices                invoices?
  items                   OrderItem[]
  statusHistory           OrderStatusHistory[]
  billingAddress          Address              @relation("BillingAddress", fields: [billingAddressId], references: [id])
  shippingAddress         Address              @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  order_status_master     order_status_master? @relation(fields: [statusMasterId], references: [id])
  user                    User                 @relation(fields: [userId], references: [id])

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([currencyCode])
  @@index([statusMasterId])
  @@map("orders")
  @@schema("public")
}

model OrderItem {
  id                  String       @id @default(uuid())
  orderId             String
  type                CartItemType
  packageId           String?
  name                String
  sku                 String?
  quantity            Int
  price               Decimal      @db.Decimal(10, 2)
  subtotal            Decimal      @db.Decimal(10, 2)
  createdAt           DateTime     @default(now())
  productId           Int?
  currencyCode        String?      @default("AED") @db.VarChar(3)
  lineDiscountExclVat Decimal?     @default(0) @db.Decimal(12, 2)
  lineSubtotalExclVat Decimal?     @db.Decimal(12, 2)
  lineTotalInclVat    Decimal?     @db.Decimal(12, 2)
  lineVatAmount       Decimal?     @db.Decimal(12, 2)
  unitDiscountExclVat Decimal?     @default(0) @db.Decimal(10, 2)
  unitPriceExclVat    Decimal?     @db.Decimal(10, 2)
  unitPriceInclVat    Decimal?     @db.Decimal(10, 2)
  unitVatAmount       Decimal?     @db.Decimal(10, 2)
  vatRateSnapshot     Decimal?     @db.Decimal(5, 4)
  order               Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package             Package?     @relation(fields: [packageId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([packageId])
  @@map("order_items")
  @@schema("public")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())
  createdBy String?
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
  @@schema("public")
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  description    String?
  type           PromoType
  value          Decimal   @db.Decimal(10, 2)
  minOrderAmount Decimal?  @db.Decimal(10, 2)
  maxDiscount    Decimal?  @db.Decimal(10, 2)
  usageLimit     Int?
  usageCount     Int       @default(0)
  isActive       Boolean   @default(true)
  startsAt       DateTime
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
  @@map("promo_codes")
  @@schema("public")
}

model Banner {
  id                                                 String          @id @default(uuid())
  title                                              String
  subtitle                                           String?
  isActive                                           Boolean         @default(true)
  createdAt                                          DateTime        @default(now())
  updatedAt                                          DateTime        @updatedAt
  ctaText                                            String?
  ctaUrl                                             String?
  displayOrder                                       Int             @default(0)
  endAt                                              DateTime?
  imageDesktopUrl                                    String          @default("")
  imageMobileUrl                                     String?
  placement                                          BannerPlacement @default(HOME_HERO)
  startAt                                            DateTime?
  image_id                                           String?
  mobile_image_id                                    String?
  media_assets_banners_image_idTomedia_assets        media_assets?   @relation("banners_image_idTomedia_assets", fields: [image_id], references: [id])
  media_assets_banners_mobile_image_idTomedia_assets media_assets?   @relation("banners_mobile_image_idTomedia_assets", fields: [mobile_image_id], references: [id])
  landingPagesAsHero                                 LandingPage[]

  @@index([placement])
  @@index([isActive])
  @@index([displayOrder])
  @@index([startAt])
  @@index([endAt])
  @@index([image_id])
  @@index([mobile_image_id])
  @@map("banners")
  @@schema("public")
}

model ContentBlock {
  id        String           @id @default(uuid())
  key       String           @unique
  type      ContentBlockType
  title     String?
  content   String
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([key])
  @@index([type])
  @@index([isActive])
  @@map("content_blocks")
  @@schema("public")
}

model LoyaltyPageConfig {
  id                String   @id @default(uuid())
  key               String   @unique @default("default")
  title             String
  subtitle          String
  ctaText           String
  ctaUrl            String
  spendAedThreshold Int      @default(1000)
  rewardAed         Int      @default(10)
  howItWorksJson    Json     @default("[]")
  faqsJson          Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([key])
  @@map("loyalty_page_config")
  @@schema("public")
}

model LandingPage {
  id             String           @id @default(uuid())
  slug           String           @unique
  title          String
  heroBannerId   String?
  seoTitle       String?
  seoDescription String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  heroBanner     Banner?          @relation(fields: [heroBannerId], references: [id])
  sections       LandingSection[]

  @@index([slug])
  @@index([isActive])
  @@map("landing_pages")
  @@schema("public")
}

model LandingSection {
  id            String             @id @default(uuid())
  landingPageId String
  type          LandingSectionType
  data          String
  displayOrder  Int                @default(0)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  config        String?
  subtitle      String?
  title         String?
  landingPage   LandingPage        @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([landingPageId])
  @@index([displayOrder])
  @@index([isActive])
  @@map("landing_sections")
  @@schema("public")
}

model NavigationMenu {
  id        String               @id @default(uuid())
  key       String               @unique
  name      String
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  items     NavigationMenuItem[]

  @@index([key])
  @@index([isActive])
  @@map("navigation_menus")
  @@schema("public")
}

model NavigationMenuItem {
  id           String               @id @default(uuid())
  menuId       String
  parentId     String?
  label        String
  url          String?
  icon         String?
  badge        String?
  badgeColor   String?
  imageUrl     String?
  description  String?
  openInNewTab Boolean              @default(false)
  sortOrder    Int                  @default(0)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  menu         NavigationMenu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent       NavigationMenuItem?  @relation("MenuItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children     NavigationMenuItem[] @relation("MenuItemChildren")

  @@index([menuId])
  @@index([parentId])
  @@index([sortOrder])
  @@map("navigation_menu_items")
  @@schema("public")
}

model BlogCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]

  @@index([slug])
  @@index([isActive])
  @@map("blog_categories")
  @@schema("public")
}

model BlogTag {
  id        String        @id @default(uuid())
  name      String        @unique
  slug      String        @unique
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  posts     BlogPostTag[]

  @@index([slug])
  @@map("blog_tags")
  @@schema("public")
}

model BlogPost {
  id              String        @id @default(uuid())
  categoryId      String
  title           String
  slug            String        @unique
  excerpt         String?
  content         String
  featuredImage   String?
  author          String?
  readTimeMinutes Int?
  isFeatured      Boolean       @default(false)
  isActive        Boolean       @default(true)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  metaTitle       String?
  metaDescription String?
  tags            BlogPostTag[]
  category        BlogCategory  @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@index([publishedAt])
  @@index([isFeatured])
  @@map("blog_posts")
  @@schema("public")
}

model BlogPostTag {
  id        String   @id @default(uuid())
  postId    String
  tagId     String
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("blog_post_tags")
  @@schema("public")
}

model ProductCollection {
  id        String                    @id @default(uuid())
  key       String                    @unique
  title     String
  subtitle  String?
  strategy  ProductCollectionStrategy @default(MANUAL)
  ruleJson  String?
  limit     Int                       @default(12)
  sortOrder Int                       @default(0)
  isActive  Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  items     ProductCollectionItem[]

  @@index([key])
  @@index([isActive])
  @@map("product_collections")
  @@schema("public")
}

model ProductCollectionItem {
  id           String            @id @default(uuid())
  collectionId String
  productId    Int
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
  @@map("product_collection_items")
  @@schema("public")
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  group     String   @default("general")
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
  @@map("site_settings")
  @@schema("public")
}

model HomePageConfig {
  id                   String            @id @default(cuid())
  key                  String            @unique @default("home")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  announcement_enabled Boolean           @default(true)
  announcement_text    String?           @db.VarChar(500)
  sections             HomePageSection[]

  @@map("home_page_configs")
  @@schema("public")
}

model HomePageSection {
  id         String          @id @default(cuid())
  homePageId String
  type       HomeSectionType
  title      String?
  subtitle   String?
  position   Int
  isEnabled  Boolean         @default(true)
  config     Json            @default("{}")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  homePage   HomePageConfig  @relation(fields: [homePageId], references: [id], onDelete: Cascade)

  @@index([homePageId])
  @@index([position])
  @@index([isEnabled])
  @@map("home_page_sections")
  @@schema("public")
}

model CategoryLandingPageConfig {
  id                 String                   @id @default(cuid())
  categoryId         String                   @unique
  heroTitle          String?
  heroSubtitle       String?
  heroImageUrl       String?
  heroImageMobileUrl String?
  ctaLabel           String?
  ctaTargetType      String?
  ctaTargetValue     String?
  isHeroEnabled      Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  sections           CategoryLandingSection[]

  @@index([categoryId])
  @@index([isHeroEnabled])
  @@map("category_landing_page_configs")
  @@schema("public")
}

model CategoryLandingSection {
  id        String                     @id @default(cuid())
  landingId String
  type      CategoryLandingSectionType
  title     String?
  position  Int
  isEnabled Boolean                    @default(true)
  config    Json                       @default("{}")
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  landing   CategoryLandingPageConfig  @relation(fields: [landingId], references: [id], onDelete: Cascade)

  @@index([landingId])
  @@index([position])
  @@index([isEnabled])
  @@map("category_landing_sections")
  @@schema("public")
}

model AnalyticsEvent {
  id        String             @id @default(uuid())
  type      AnalyticsEventType
  userId    String?
  metadata  String?
  sessionId String?
  ipAddress String?
  userAgent String?
  createdAt DateTime           @default(now())
  productId Int?
  user      User?              @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([userId])
  @@index([productId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("analytics_events")
  @@schema("public")
}

model SavedSearchTerm {
  id          String   @id @default(uuid())
  term        String
  resultCount Int
  userId      String?
  sessionId   String?
  createdAt   DateTime @default(now())

  @@index([term])
  @@index([userId])
  @@index([createdAt])
  @@map("saved_search_terms")
  @@schema("public")
}

model InvCountry {
  id          Int          @id(map: "v2_countries_pkey") @default(autoincrement())
