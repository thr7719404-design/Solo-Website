  specs             Json?                     @default("[]")
  deliveryNote      String?                   @map("delivery_note") @db.VarChar(500)
  returnsNote       String?                   @map("returns_note") @db.VarChar(500)
  isActive          Boolean                   @default(true) @map("is_active")
  isDiscontinued    Boolean                   @default(false) @map("is_discontinued")
  isFeatured        Boolean                   @default(false) @map("is_featured")
  isNew             Boolean                   @default(false) @map("is_new")
  isBestSeller      Boolean                   @default(false) @map("is_best_seller")
  metaTitle         String?                   @map("meta_title") @db.VarChar(200)
  metaDescription   String?                   @map("meta_description") @db.VarChar(500)
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  import_job_rows   import_job_rows[]
  transactions      InvInventoryTransaction[]
  dimensions        InvProductDimension?
  images            InvProductImage[]
  product_overrides ProductOverride?
  packaging         InvProductPackaging?
  pricing           InvProductPricing?
  specifications    InvProductSpecification[]
  product_variants  product_variants[]
  brand             InvBrand?                 @relation(fields: [brandId], references: [id], onUpdate: NoAction, map: "v2_products_brand_id_fkey")
  category          InvCategory?              @relation(fields: [categoryId], references: [id], onUpdate: NoAction, map: "v2_products_category_id_fkey")
  country           InvCountry?               @relation(fields: [countryId], references: [id], onUpdate: NoAction, map: "v2_products_country_id_fkey")
  designer          InvDesigner?              @relation(fields: [designerId], references: [id], onUpdate: NoAction, map: "v2_products_designer_id_fkey")
  subcategory       InvSubcategory?           @relation(fields: [subcategoryId], references: [id], onUpdate: NoAction, map: "v2_products_subcategory_id_fkey")

