generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  firstName               String?
  lastName                String?
  phone                   String?
  role                    UserRole                 @default(CUSTOMER)
  isActive                Boolean                  @default(true)
  emailVerified           Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  lastLoginAt             DateTime?
  addresses               Address[]
  cart                    Cart[]
  emailVerificationTokens EmailVerificationToken[]
  favorites               Favorite[]
  loyaltyWallet           LoyaltyWallet?
  orders                  Order[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  savedPaymentMethods     SavedPaymentMethod[]
  returns                 Return[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verification_tokens")
}

model LoyaltyWallet {
  id               String               @id @default(uuid())
  userId           String               @unique
  balanceAed       Decimal              @default(0) @db.Decimal(10, 2)
  totalEarnedAed   Decimal              @default(0) @db.Decimal(10, 2)
  totalRedeemedAed Decimal              @default(0) @db.Decimal(10, 2)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  transactions     LoyaltyTransaction[]
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loyalty_wallets")
}

model LoyaltyTransaction {
  id          String                 @id @default(uuid())
  walletId    String
  type        LoyaltyTransactionType
  amountAed   Decimal                @db.Decimal(10, 2)
  description String?
  orderId     String?
  createdAt   DateTime               @default(now())
  wallet      LoyaltyWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([orderId])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

model SavedPaymentMethod {
  id                      String   @id @default(uuid())
  userId                  String
  provider                String   @default("stripe")
  providerPaymentMethodId String
  brand                   String
  last4                   String   @db.VarChar(4)
  expMonth                Int
  expYear                 Int
  isDefault               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isDefault])
  @@map("saved_payment_methods")
}

model Address {
  id             String   @id @default(uuid())
  userId         String
  firstName      String
  lastName       String
  addressLine1   String
  addressLine2   String?
  city           String
  postalCode     String?
  phone          String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  label          String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ordersBilling  Order[]  @relation("BillingAddress")
  ordersShipping Order[]  @relation("ShippingAddress")

  @@index([userId])
  @@map("addresses")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("favorites")
}

model ProductOverride {
  id                      String   @id(map: "v2_product_overrides_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id              Int      @unique(map: "v2_product_overrides_product_id_key")
  is_featured_override    Boolean?
  is_new_override         Boolean?
  is_best_seller_override Boolean?
  homepage_rank           Int?
  custom_price_aed        Decimal? @db.Decimal(10, 2)
  custom_sale_price_aed   Decimal? @db.Decimal(10, 2)
  is_on_sale              Boolean  @default(false)
  product_sale_percent    Decimal? @db.Decimal(5, 2)
  product_sale_name       String?  @db.VarChar(50)
  product_sale_starts_at  DateTime? @db.Timestamp(6)
  product_sale_ends_at    DateTime? @db.Timestamp(6)
  custom_description      String?
  custom_long_description String?
  meta_title              String?  @db.VarChar(200)
  meta_description        String?  @db.VarChar(500)
  meta_keywords           String?  @db.VarChar(500)
  notes                   String?
  created_at              DateTime @default(now()) @db.Timestamp(6)
  updated_at              DateTime @default(now()) @db.Timestamp(6)
  created_by              String?  @db.Uuid
  updated_by              String?  @db.Uuid
  products                Product  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "v2_product_overrides_product_id_fkey")

  @@index([product_id], map: "idx_product_overrides_product_id")
  @@map("product_overrides")
}

model Package {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  description     String?
  longDescription String?
  image           String?
  price           Decimal       @db.Decimal(10, 2)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cartItems       CartItem[]
  orderItems      OrderItem[]
  items           PackageItem[]

  @@index([slug])
  @@index([isFeatured])
  @@index([isActive])
  @@map("packages")
}

model PackageItem {
  id        String  @id @default(uuid())
  packageId String
  quantity  Int     @default(1)
  productId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, productId])
  @@index([packageId])
  @@index([productId])
  @@map("package_items")
}

model Cart {
  id            String     @id @default(uuid())
  userId        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  promoCode     String?    @db.VarChar(50)
  promoCodeId   String?
  promoDiscount Decimal?   @db.Decimal(10, 2)
  guestKey      String?    @db.Uuid
  createdFrom   String?    @db.VarChar(30)
  items         CartItem[]
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String       @id @default(uuid())
  cartId    String
  type      CartItemType
  packageId String?
  quantity  Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  productId Int?
  cart      Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  package   Package?     @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productId])
  @@index([packageId])
  @@map("cart_items")
}

model Order {
  id                      String               @id @default(uuid())
  orderNumber             String               @unique
  userId                  String
  status                  OrderStatus          @default(PENDING)
  paymentStatus           PaymentStatus        @default(PENDING)
  shippingAddressId       String?
  billingAddressId        String?
  shippingMethod          ShippingMethod
  shippingCost            Decimal              @db.Decimal(10, 2)
  trackingNumber          String?
  subtotal                Decimal              @db.Decimal(10, 2)
  discount                Decimal              @default(0) @db.Decimal(10, 2)
  vat                     Decimal              @map("tax") @db.Decimal(10, 2)
  total                   Decimal              @db.Decimal(10, 2)
  promoCode               String?
  paymentIntentId         String?
  notes                   String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  paidAt                  DateTime?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  paymentMethod           PaymentMethod        @default(CREDIT_CARD)
  billingInvoiceCompany   String?              @db.VarChar(60)
  billingInvoiceVatNumber String?              @db.VarChar(60)
  loyaltyRedeemAed        Decimal?             @db.Decimal(10, 2)
  loyaltyEarnAed          Decimal?             @default(0) @db.Decimal(10, 2)
  statusMasterId          String?
  shippingCompany         String?
  trackingUrl             String?
  currencyCode            String               @default("AED") @db.VarChar(3)
  discountExclVat         Decimal?             @default(0) @db.Decimal(12, 2)
  globalSaleId            String?
  globalSaleName          String?              @db.VarChar(100)
  globalSalePercent       Decimal?             @db.Decimal(5, 4)
  promoDiscountType       String?              @db.VarChar(20)
  promoDiscountValue      Decimal?             @db.Decimal(10, 2)
  shippingExclVat         Decimal?             @db.Decimal(12, 2)
  shippingVatAmount       Decimal?             @db.Decimal(12, 2)
  subtotalExclVat         Decimal?             @db.Decimal(12, 2)
  totalInclVat            Decimal?             @db.Decimal(12, 2)
  vatAmount               Decimal?             @db.Decimal(12, 2)
  vatRateSnapshot         Decimal?             @db.Decimal(5, 4)
  invoices                invoices?
  items                   OrderItem[]
  statusHistory           OrderStatusHistory[]
  returns                 Return[]
  billingAddress          Address?             @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  shippingAddress         Address?             @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  order_status_master     order_status_master? @relation(fields: [statusMasterId], references: [id])
  user                    User                 @relation(fields: [userId], references: [id])

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([currencyCode])
  @@index([statusMasterId])
  @@map("orders")
}

model OrderItem {
  id                  String       @id @default(uuid())
  orderId             String
  type                CartItemType
  packageId           String?
  name                String
  sku                 String?
  quantity            Int
  price               Decimal      @db.Decimal(10, 2)
  subtotal            Decimal      @db.Decimal(10, 2)
  createdAt           DateTime     @default(now())
  productId           Int?
  currencyCode        String?      @default("AED") @db.VarChar(3)
  lineDiscountExclVat Decimal?     @default(0) @db.Decimal(12, 2)
  lineSubtotalExclVat Decimal?     @db.Decimal(12, 2)
  lineTotalInclVat    Decimal?     @db.Decimal(12, 2)
  lineVatAmount       Decimal?     @db.Decimal(12, 2)
  unitDiscountExclVat Decimal?     @default(0) @db.Decimal(10, 2)
  unitPriceExclVat    Decimal?     @db.Decimal(10, 2)
  unitPriceInclVat    Decimal?     @db.Decimal(10, 2)
  unitVatAmount       Decimal?     @db.Decimal(10, 2)
  vatRateSnapshot     Decimal?     @db.Decimal(5, 4)
  order               Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package             Package?     @relation(fields: [packageId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([packageId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())
  createdBy String?
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  description    String?
  type           PromoType
  value          Decimal   @db.Decimal(10, 2)
  minOrderAmount Decimal?  @db.Decimal(10, 2)
  maxDiscount    Decimal?  @db.Decimal(10, 2)
  usageLimit     Int?
  usageCount     Int       @default(0)
  isActive       Boolean   @default(true)
  startsAt       DateTime
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
  @@map("promo_codes")
}

model Banner {
  id                                                 String          @id @default(uuid())
  title                                              String
  subtitle                                           String?
  isActive                                           Boolean         @default(true)
  createdAt                                          DateTime        @default(now())
  updatedAt                                          DateTime        @updatedAt
  ctaText                                            String?
  ctaUrl                                             String?
  displayOrder                                       Int             @default(0)
  endAt                                              DateTime?
  imageDesktopUrl                                    String          @default("")
  imageMobileUrl                                     String?
  placement                                          BannerPlacement @default(HOME_HERO)
  startAt                                            DateTime?
  image_id                                           String?
  mobile_image_id                                    String?
  media_assets_banners_image_idTomedia_assets        media_assets?   @relation("banners_image_idTomedia_assets", fields: [image_id], references: [id])
  media_assets_banners_mobile_image_idTomedia_assets media_assets?   @relation("banners_mobile_image_idTomedia_assets", fields: [mobile_image_id], references: [id])
  landingPagesAsHero                                 LandingPage[]

  @@index([placement])
  @@index([isActive])
  @@index([displayOrder])
  @@index([startAt])
  @@index([endAt])
  @@index([image_id])
  @@index([mobile_image_id])
  @@map("banners")
}


model LoyaltyPageConfig {
  id                String   @id @default(uuid())
  key               String   @unique @default("default")
  title             String
  subtitle          String
  ctaText           String
  ctaUrl            String
  spendAedThreshold Int      @default(1000)
  rewardAed         Int      @default(10)
  howItWorksJson    Json     @default("[]")
  faqsJson          Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([key])
  @@map("loyalty_page_config")
}

model LandingPage {
  id             String           @id @default(uuid())
  slug           String           @unique
  title          String
  heroBannerId   String?
  seoTitle       String?
  seoDescription String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  heroBanner     Banner?          @relation(fields: [heroBannerId], references: [id])
  sections       LandingSection[]

  @@index([slug])
  @@index([isActive])
  @@map("landing_pages")
}

model LandingSection {
  id            String             @id @default(uuid())
  landingPageId String
  type          LandingSectionType
  data          String
  displayOrder  Int                @default(0)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  config        String?
  subtitle      String?
  title         String?
  landingPage   LandingPage        @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([landingPageId])
  @@index([displayOrder])
  @@index([isActive])
  @@map("landing_sections")
}

model NavigationMenu {
  id        String               @id @default(uuid())
  key       String               @unique
  name      String
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  items     NavigationMenuItem[]

  @@index([key])
  @@index([isActive])
  @@map("navigation_menus")
}

model NavigationMenuItem {
  id           String               @id @default(uuid())
  menuId       String
  parentId     String?
  label        String
  url          String?
  icon         String?
  badge        String?
  badgeColor   String?
  imageUrl     String?
  description  String?
  openInNewTab Boolean              @default(false)
  sortOrder    Int                  @default(0)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  menu         NavigationMenu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent       NavigationMenuItem?  @relation("MenuItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children     NavigationMenuItem[] @relation("MenuItemChildren")

  @@index([menuId])
  @@index([parentId])
  @@index([sortOrder])
  @@map("navigation_menu_items")
}

model BlogCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]

  @@index([slug])
  @@index([isActive])
  @@map("blog_categories")
}

model BlogTag {
  id        String        @id @default(uuid())
  name      String        @unique
  slug      String        @unique
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  posts     BlogPostTag[]

  @@index([slug])
  @@map("blog_tags")
}

model BlogPost {
  id              String        @id @default(uuid())
  categoryId      String
  title           String
  slug            String        @unique
  excerpt         String?
  content         String
  featuredImage   String?
  author          String?
  readTimeMinutes Int?
  isFeatured      Boolean       @default(false)
  isActive        Boolean       @default(true)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  metaTitle       String?
  metaDescription String?
  tags            BlogPostTag[]
  category        BlogCategory  @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@index([publishedAt])
  @@index([isFeatured])
  @@map("blog_posts")
}

model BlogPostTag {
  id        String   @id @default(uuid())
  postId    String
  tagId     String
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("blog_post_tags")
}

model ProductCollection {
  id        String                    @id @default(uuid())
  key       String                    @unique
  title     String
  subtitle  String?
  strategy  ProductCollectionStrategy @default(MANUAL)
  ruleJson  String?
  limit     Int                       @default(12)
  sortOrder Int                       @default(0)
  isActive  Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  items     ProductCollectionItem[]

  @@index([key])
  @@index([isActive])
  @@map("product_collections")
}

model ProductCollectionItem {
  id           String            @id @default(uuid())
  collectionId String
  productId    Int
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
  @@map("product_collection_items")
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  group     String   @default("general")
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
  @@map("site_settings")
}

model HomePageConfig {
  id                   String            @id @default(cuid())
  key                  String            @unique @default("home")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  announcement_enabled Boolean           @default(true)
  announcement_text    String?           @db.VarChar(500)
  sections             HomePageSection[]

  @@map("home_page_configs")
}

model HomePageSection {
  id         String          @id @default(cuid())
  homePageId String
  type       HomeSectionType
  title      String?
  subtitle   String?
  position   Int
  isEnabled  Boolean         @default(true)
  config     Json            @default("{}")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  homePage   HomePageConfig  @relation(fields: [homePageId], references: [id], onDelete: Cascade)

  @@index([homePageId])
  @@index([position])
  @@index([isEnabled])
  @@map("home_page_sections")
}

model CategoryLandingPageConfig {
  id                 String                   @id @default(cuid())
  categoryId         String                   @unique
  heroTitle          String?
  heroSubtitle       String?
  heroImageUrl       String?
  heroImageMobileUrl String?
  ctaLabel           String?
  ctaTargetType      String?
  ctaTargetValue     String?
  isHeroEnabled      Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  sections           CategoryLandingSection[]

  @@index([categoryId])
  @@index([isHeroEnabled])
  @@map("category_landing_page_configs")
}

model CategoryLandingSection {
  id        String                     @id @default(cuid())
  landingId String
  type      CategoryLandingSectionType
  title     String?
  position  Int
  isEnabled Boolean                    @default(true)
  config    Json                       @default("{}")
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  landing   CategoryLandingPageConfig  @relation(fields: [landingId], references: [id], onDelete: Cascade)

  @@index([landingId])
  @@index([position])
  @@index([isEnabled])
  @@map("category_landing_sections")
}

// ── Inventory / Product models (formerly Inv* prefixed) ──────────────

model Country {
  id          Int       @id(map: "v2_countries_pkey") @default(autoincrement())
  countryCode String    @unique(map: "v2_countries_country_code_key") @map("country_code") @db.VarChar(3)
  countryName String    @map("country_name") @db.VarChar(100)
  is_active   Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  products    Product[]

  @@map("countries")
}

model Brand {
  id          Int       @id(map: "v2_brands_pkey") @default(autoincrement())
  name        String    @unique(map: "v2_brands_name_key") @db.VarChar(100)
  name_ar     String?   @db.VarChar(100)
  slug        String    @unique(map: "v2_brands_slug_key") @db.VarChar(100)
  description String?
  logo_id     String?   @db.Uuid
  website     String?   @db.VarChar(255)
  sort_order  Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  products    Product[]

  @@index([isActive], map: "idx_brands_is_active")
  @@index([slug], map: "idx_brands_slug")
  @@map("brands")
}

model Designer {
  id        Int       @id(map: "v2_designers_pkey") @default(autoincrement())
  name      String    @unique(map: "v2_designers_name_key") @db.VarChar(100)
  slug      String    @unique(map: "v2_designers_slug_key") @db.VarChar(100)
  bio       String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  products  Product[]

  @@map("designers")
}

model Category {
  id               Int           @id(map: "v2_categories_pkey") @default(autoincrement())
  name             String        @unique(map: "v2_categories_name_key") @db.VarChar(100)
  name_ar          String?       @db.VarChar(100)
  slug             String        @unique(map: "v2_categories_slug_key") @db.VarChar(100)
  description      String?
  image_id         String?       @db.Uuid
  parent_id        Int?
  sort_order       Int           @default(0)
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  categories       Category?     @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction, map: "categories_parent_fk")
  other_categories Category[]    @relation("categoriesTocategories")
  products         Product[]
  subcategories    Subcategory[]

  @@index([isActive], map: "idx_categories_is_active")
  @@index([parent_id], map: "idx_categories_parent_id")
  @@index([slug], map: "idx_categories_slug")
  @@map("categories")
}

model Subcategory {
  id          Int       @id(map: "v2_subcategories_pkey") @default(autoincrement())
  categoryId  Int       @map("category_id")
  name        String    @db.VarChar(100)
  name_ar     String?   @db.VarChar(100)
  slug        String    @db.VarChar(100)
  description String?
  sort_order  Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  products    Product[]
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "v2_subcategories_category_id_fkey")

  @@unique([categoryId, slug], map: "idx_subcategories_category_slug")
  @@unique([categoryId, name], map: "v2_subcategories_category_id_name_key")
  @@index([categoryId], map: "idx_subcategories_category_id")
  @@index([slug], map: "idx_subcategories_slug")
  @@map("subcategories")
}

model Product {
  id                Int                      @id(map: "v2_products_pkey") @default(autoincrement())
  sku               String                   @unique(map: "v2_products_sku_key") @db.VarChar(50)
  productName       String                   @map("name") @db.VarChar(255)
  name_ar           String?                  @db.VarChar(255)
  slug              String                   @unique(map: "v2_products_slug_key") @db.VarChar(255)
  description       String?
  shortDescription  String?                  @map("short_description") @db.VarChar(500)
  fullDescription   String?                  @map("full_description")
  categoryId        Int?                     @map("category_id")
  subcategoryId     Int?                     @map("subcategory_id")
  brandId           Int?                     @map("brand_id")
  designerId        Int?                     @map("designer_id")
  countryId         Int?                     @map("country_id")
  material          String?                  @db.VarChar(255)
  colour            String?                  @db.VarChar(100)
  size              String?                  @db.VarChar(50)
  ean               BigInt?
  barcode           String?                  @db.VarChar(100)
  highlights        Json?                    @default("[]")
  specs             Json?                    @default("[]")
  deliveryNote      String?                  @map("delivery_note") @db.VarChar(500)
  returnsNote       String?                  @map("returns_note") @db.VarChar(500)
  isActive          Boolean                  @default(true) @map("is_active")
  isDiscontinued    Boolean                  @default(false) @map("is_discontinued")
  isFeatured        Boolean                  @default(false) @map("is_featured")
  isNew             Boolean                  @default(false) @map("is_new")
  isBestSeller      Boolean                  @default(false) @map("is_best_seller")
  metaTitle         String?                  @map("meta_title") @db.VarChar(200)
  metaDescription   String?                  @map("meta_description") @db.VarChar(500)
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  dimensions        ProductDimension?
  images            ProductImage[]
  product_overrides ProductOverride?
  packaging         ProductPackaging?
  pricing           ProductPricing?
  specifications    ProductSpecification[]
  product_variants  product_variants[]
  brand             Brand?                   @relation(fields: [brandId], references: [id], onUpdate: NoAction, map: "v2_products_brand_id_fkey")
  category          Category?                @relation(fields: [categoryId], references: [id], onUpdate: NoAction, map: "v2_products_category_id_fkey")
  country           Country?                 @relation(fields: [countryId], references: [id], onUpdate: NoAction, map: "v2_products_country_id_fkey")
  designer          Designer?                @relation(fields: [designerId], references: [id], onUpdate: NoAction, map: "v2_products_designer_id_fkey")
  subcategory       Subcategory?             @relation(fields: [subcategoryId], references: [id], onUpdate: NoAction, map: "v2_products_subcategory_id_fkey")
  stockQty          Int                      @default(0) @map("stock_qty")
  reservedQty       Int                      @default(0) @map("reserved_qty")
  lowStockAlert     Int                      @default(5) @map("low_stock_alert")
  stockMovements    StockMovement[]

  @@index([brandId], map: "idx_products_brand_id")
  @@index([categoryId], map: "idx_products_category_id")
  @@index([createdAt], map: "idx_products_created_at")
  @@index([isActive], map: "idx_products_is_active")
  @@index([isFeatured], map: "idx_products_is_featured")
  @@index([sku], map: "idx_products_sku")
  @@index([slug], map: "idx_products_slug")
  @@map("products")
}

model ProductDimension {
  id               Int      @id(map: "v2_product_dimensions_pkey") @default(autoincrement())
  productId        Int      @unique(map: "v2_product_dimensions_product_id_key") @map("product_id")
  length_cm        Decimal? @db.Decimal(10, 2)
  width_cm         Decimal? @db.Decimal(10, 2)
  height_cm        Decimal? @db.Decimal(10, 2)
  diameter_cm      Decimal? @db.Decimal(10, 2)
  capacity_liter   Decimal? @db.Decimal(10, 3)
  weight_kg        Decimal? @db.Decimal(10, 3)
  packed_length_cm Decimal? @db.Decimal(10, 2)
  packedWidthCm    Decimal? @map("packed_width_cm") @db.Decimal(10, 2)
  packedHeightCm   Decimal? @map("packed_height_cm") @db.Decimal(10, 2)
