// ── Returns / RMA ──

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  ITEMS_RECEIVED
  REFUND_PROCESSING
  COMPLETED
  CANCELLED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  ARRIVED_LATE
  DAMAGED_IN_SHIPPING
  OTHER
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  LOYALTY_CASH
  STORE_CREDIT
}

model Return {
  id              String       @id @default(uuid())
  returnNumber    String       @unique
  orderId         String
  userId          String
  status          ReturnStatus @default(REQUESTED)
  reason          ReturnReason
  customerNotes   String?
  adminNotes      String?
  refundMethod    RefundMethod @default(ORIGINAL_PAYMENT)
  refundAmount    Decimal      @default(0) @db.Decimal(10, 2)
  loyaltyDeducted Decimal      @default(0) @db.Decimal(10, 2)
  stockRestored   Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  approvedAt      DateTime?
  receivedAt      DateTime?
  completedAt     DateTime?
  items           ReturnItem[]
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([returnNumber])
  @@index([createdAt])
  @@map("returns")
}

model ReturnItem {
  id          String @id @default(uuid())
  returnId    String
  orderItemId String
  productId   Int?
  name        String
  sku         String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)
  return      Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([orderItemId])
  @@map("return_items")
}
