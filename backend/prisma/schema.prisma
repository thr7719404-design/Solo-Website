model invoices {
  id              String   @id @default(cuid())
  orderId         String   @unique
  invoiceNumber   String   @unique
  issuedAt        DateTime @default(now())
  invoiceDate     DateTime @default(now()) @map("invoice_date")
  dueDate         DateTime? @map("due_date")
  currencyCode    String   @default("AED") @db.VarChar(3)
  vatRateSnapshot Decimal  @db.Decimal(5, 4)
  sellerName      String   @db.VarChar(200)
  sellerAddress   String
  sellerVatNumber String?  @map("sellerTaxNumber") @db.VarChar(50)
  buyerName       String   @db.VarChar(200)
  buyerAddress    String
  buyerVatNumber  String?  @map("buyerTaxNumber") @db.VarChar(50)
  subtotalExclVat Decimal  @db.Decimal(12, 2)
  discountExclVat Decimal  @default(0) @db.Decimal(12, 2)
  vatAmount       Decimal  @db.Decimal(12, 2)
  shippingExclVat Decimal  @default(0) @db.Decimal(12, 2)
  shippingVat     Decimal  @default(0) @db.Decimal(12, 2)
  totalInclVat    Decimal  @db.Decimal(12, 2)
  pdfStoragePath  String?  @db.VarChar(500)
  pdfUrl          String?  @db.VarChar(500) @map("pdf_url")
  status          String   @default("issued") @db.VarChar(50)
