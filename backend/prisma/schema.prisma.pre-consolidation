// ============================================================================
// INVENTORY SCHEMA - Product Catalog (formerly inventory_db)
// ============================================================================

model InvCountry {
  id          Int       @id @default(autoincrement())
  countryCode String    @unique @map("country_code") @db.VarChar(3)
  countryName String    @map("country_name") @db.VarChar(100)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  products InvProduct[]

  @@index([countryCode])
  @@map("countries")
  @@schema("inventory")
}

model InvBrand {
  id          Int       @id @default(autoincrement())
  brandName   String    @unique @map("brand_name") @db.VarChar(100)
  description String?   @db.Text
  website     String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  products InvProduct[]

  @@index([brandName])
  @@index([isActive])
  @@map("brands")
  @@schema("inventory")
}

model InvDesigner {
  id           Int       @id @default(autoincrement())
  designerName String    @unique @map("designer_name") @db.VarChar(100)
  bio          String?   @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  products InvProduct[]

  @@index([designerName])
  @@map("designers")
  @@schema("inventory")
}

model InvCategory {
  id           Int       @id @default(autoincrement())
  categoryName String    @unique @map("category_name") @db.VarChar(100)
  description  String?   @db.Text
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  subcategories InvSubcategory[]
  products      InvProduct[]

  @@index([categoryName])
  @@index([isActive])
  @@map("categories")
  @@schema("inventory")
}

model InvSubcategory {
  id              Int       @id @default(autoincrement())
  categoryId      Int       @map("category_id")
  subcategoryName String    @map("subcategory_name") @db.VarChar(100)
  description     String?   @db.Text
  displayOrder    Int       @default(0) @map("display_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  category InvCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products InvProduct[]

  @@unique([categoryId, subcategoryName])
  @@index([categoryId])
  @@index([subcategoryName])
  @@map("subcategories")
  @@schema("inventory")
}

model InvProduct {
  id             Int       @id @default(autoincrement())
  sku            String    @unique @db.VarChar(50)
  sku2025        String?   @map("sku_2025") @db.VarChar(50)
  sku2026        String?   @map("sku_2026") @db.VarChar(50)
  productName    String    @map("name") @db.VarChar(255)
  nameEnglish    String?   @map("name_english") @db.VarChar(255)
  description    String?   @db.Text
  
  // ==== NEW: Product Page Fields v1 ====
  shortDescription    String?   @map("short_description") @db.VarChar(500)
  fullDescription     String?   @map("full_description") @db.Text
  highlights          Json?     @default("[]")  // Array of strings, e.g. ["Dishwasher Safe", "BPA Free"]
  galleryImageUrls    Json?     @map("gallery_image_urls") @default("[]")  // Array of image URL strings
  specs               Json?     @default("[]")  // Array of {key, value} objects
  deliveryNote        String?   @map("delivery_note") @db.VarChar(500)
  returnsNote         String?   @map("returns_note") @db.VarChar(500)
  urlSlug             String?   @map("url_slug") @db.VarChar(255)
  metaTitle           String?   @map("meta_title") @db.VarChar(200)
  metaDescription     String?   @map("meta_description") @db.VarChar(500)
  // ==== END: Product Page Fields v1 ====
  
  categoryId     Int?      @map("category_id")
  subcategoryId  Int?      @map("subcategory_id")
  brandId        Int?      @map("brand_id")
  designerId     Int?      @map("designer_id")
  countryId      Int?      @map("country_id")
  material       String?   @db.VarChar(255)
  colour         String?   @db.VarChar(100)
  size           String?   @db.VarChar(50)
  ean            BigInt?
  eanSecondary   BigInt?   @map("ean_secondary")
  customsTariff  BigInt?   @map("customs_tariff_number")
  dishwasherSafe Boolean?  @map("dishwasher_safe")
  cleaningMaint  String?   @map("cleaning_maintenance") @db.Text
  isActive       Boolean   @default(true) @map("is_active")
  isDiscontinued Boolean   @default(false) @map("is_discontinued")
  isFeatured     Boolean   @default(false) @map("is_featured")
  isNew          Boolean   @default(false) @map("is_new")
  isBestSeller   Boolean   @default(false) @map("is_best_seller")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relations
  category       InvCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory    InvSubcategory?        @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  brand          InvBrand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  designer       InvDesigner?           @relation(fields: [designerId], references: [id], onDelete: SetNull)
  country        InvCountry?            @relation(fields: [countryId], references: [id], onDelete: SetNull)
  
  dimensions     InvProductDimension?
  packaging      InvProductPackaging?
  pricing        InvProductPricing?
  images         InvProductImage[]
  specifications InvProductSpecification[]
  transactions   InvInventoryTransaction[]

  @@index([sku])
  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isNew])
  @@index([isBestSeller])
  @@map("products")
  @@schema("inventory")
}

model InvProductDimension {
  id                       Int      @id @default(autoincrement())
  productId                Int      @unique @map("product_id")
  functionalDepthCm        Decimal? @map("functional_depth_cm") @db.Decimal(10, 2)
  functionalWidthCm        Decimal? @map("functional_width_cm") @db.Decimal(10, 2)
  functionalHeightCm       Decimal? @map("functional_height_cm") @db.Decimal(10, 2)
  functionalDiameterCm     Decimal? @map("functional_diameter_cm") @db.Decimal(10, 2)
  functionalCapacityLiter  Decimal? @map("functional_capacity_liter") @db.Decimal(10, 3)
  packedWeightKg           Decimal? @map("packed_weight_kg") @db.Decimal(10, 3)
  packedDepthCm            Decimal? @map("packed_depth_cm") @db.Decimal(10, 2)
  packedWidthCm            Decimal? @map("packed_width_cm") @db.Decimal(10, 2)
  packedHeightCm           Decimal? @map("packed_height_cm") @db.Decimal(10, 2)
  productWeightKg          Decimal? @map("product_weight_kg") @db.Decimal(10, 3)
  technicalCapacityLiter   Decimal? @map("technical_capacity_liter") @db.Decimal(10, 3)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at")

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_dimensions")
  @@schema("inventory")
}

model InvProductPackaging {
  id                   Int      @id @default(autoincrement())
  productId            Int      @unique @map("product_id")
  packagingType        String?  @map("packaging_type") @db.VarChar(100)
  colliSize            Int?     @map("colli_size")
  colliWeightKg        Decimal? @map("colli_weight_kg") @db.Decimal(10, 3)
  colliLengthCm        Decimal? @map("colli_length_cm") @db.Decimal(10, 2)
  colliWidthCm         Decimal? @map("colli_width_cm") @db.Decimal(10, 2)
  colliHeightCm        Decimal? @map("colli_height_cm") @db.Decimal(10, 2)
  masterColliWeightKg  Decimal? @map("master_colli_weight_kg") @db.Decimal(10, 3)
  masterColliLengthCm  Decimal? @map("master_colli_length_cm") @db.Decimal(10, 2)
  masterColliWidthCm   Decimal? @map("master_colli_width_cm") @db.Decimal(10, 2)
  masterColliHeightCm  Decimal? @map("master_colli_height_cm") @db.Decimal(10, 2)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_packaging")
  @@schema("inventory")
}

model InvProductPricing {
  id               Int       @id @default(autoincrement())
  productId        Int       @unique @map("product_id")
  rrpAedExclVat    Decimal?  @map("rrp_aed_excl_vat") @db.Decimal(10, 2)
  priceInclVat     Decimal?  @map("price_incl_vat") @db.Decimal(10, 2)
  listedPriceVat   Decimal?  @map("listed_price_incl_vat") @db.Decimal(10, 2)
  currency         String    @default("AED") @db.VarChar(3)
  vatRate          Decimal?  @map("vat_rate") @db.Decimal(5, 2)
  isCurrent        Boolean   @default(true) @map("is_current")
  effectiveFrom    DateTime? @map("effective_from") @db.Date
  effectiveTo      DateTime? @map("effective_to") @db.Date
  remarks          String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_pricing")
  @@schema("inventory")
}

model InvProductImage {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  imageUrl     String   @map("image_url") @db.VarChar(500)
  imageType    String?  @map("image_type") @db.VarChar(50)
  altText      String?  @map("alt_text") @db.VarChar(255)
  displayOrder Int      @default(0) @map("display_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([displayOrder])
  @@map("product_images")
  @@schema("inventory")
}

model InvProductSpecification {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  specKey      String   @map("spec_key") @db.VarChar(100)
  specValue    String?  @map("spec_value") @db.Text
  specUnit     String?  @map("spec_unit") @db.VarChar(50)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_specifications")
  @@schema("inventory")
}

model InvInventoryTransaction {
  id              Int      @id @default(autoincrement())
  productId       Int      @map("product_id")
  transactionType String   @map("transaction_type") @db.VarChar(50)
  quantity        Int
  quantityBefore  Int      @map("quantity_before")
  quantityAfter   Int      @map("quantity_after")
  reference       String?  @db.VarChar(100)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String?  @map("created_by") @db.VarChar(100)

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([transactionType])
  @@index([createdAt])
  @@map("inventory_transactions")
  @@schema("inventory")
}
